{
  "name": "github-release-notification-api",
  "version": "1.0.0",
  "type": "module",
  "description": "An api that lets users subscribe to email notifications about github repo releases",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/migrate.js && node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migration:generate": "drizzle-kit generate --config drizzle.config.ts",
    "migration:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --check 'src/**/*.{ts,tsx,json,md}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlegKorniychuk/github-release-notification-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/OlegKorniychuk/github-release-notification-api/issues"
  },
  "homepage": "https://github.com/OlegKorniychuk/github-release-notification-api#readme",
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^1.0.0-beta.20",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "bullmq": "^5.73.4",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^1.0.0-beta.20",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  }
}
